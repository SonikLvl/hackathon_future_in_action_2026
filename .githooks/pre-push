#!/usr/bin/env sh
set -eu

zero_sha="0000000000000000000000000000000000000000"
repo_root="$(git rev-parse --show-toplevel)"

cd "$repo_root"

should_check_frontend=false

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    if git rev-parse --verify origin/main >/dev/null 2>&1; then
      base_sha="$(git merge-base "$local_sha" origin/main)"
      changed_files="$(git diff --name-only "$base_sha" "$local_sha")"
    else
      changed_files="$(git diff-tree --no-commit-id --name-only -r "$local_sha")"
    fi
  else
    changed_files="$(git diff --name-only "$remote_sha" "$local_sha")"
  fi

  if echo "$changed_files" | grep -q "^frontend/"; then
    should_check_frontend=true
    break
  fi
done

if [ "$should_check_frontend" != "true" ]; then
  echo "No frontend changes in pushed commits. Skipping frontend pre-push checks."
  exit 0
fi

echo "Running frontend pre-push checks..."

cd frontend

npm run check
