# Віртуальне середовище — у кожного своя машина, своя збірка
venv/
.venv/
env/

# Python-кеш і скомпільовані файли
__pycache__/
*.pyc
*.pyo
*.pyd

# Секрети — паролі, ключі, токени (ОБОВ'ЯЗКОВО в ігнор)
.env
.env.local
*.pem
*.key

# Логи й тимчасові файли
*.log
*.tmp

# IDE / редактор (особисті налаштування, не для команди)
.vscode/
.idea/
*.swp

# OS-специфічне сміття
.DS_Store
Thumbs.db

# Якщо буде фронтенд (Node.js)
node_modules/
dist/
build/

# Бази даних, якщо локально щось генерується
*.sqlite3
*.db